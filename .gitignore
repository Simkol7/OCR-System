# 忽略编译缓存
__pycache__/
*.py[cod]
*$py.class

# 忽略深度学习模型文件 (极其重要)
models/
*.onnx
*.pdmodel
*.pdiparams
*.tar

# 忽略测试输出图片，保留CSV实验结果
output/*.jpg
output/*.png
output/*.jpeg
!output/
!output/*.csv
*.jpg
*.png
*.jpeg
# 保留 README 中使用的示例测试图
!test/test_image.jpg
!test_dataset/
!test_dataset/basic_2.png

# 忽略虚拟环境
venv/
env/
.env
